# OpenAI-compatible API (required for LLM and embeddings)
OPENAI_API_KEY=sk-...
# Optional: custom base URL
# OPENAI_BASE_URL=https://api.openai.com/v1

# Pinecone (required for RAG)
PINECONE_API_KEY=...
PINECONE_INDEX_NAME=cursor-clone-index
# Optional for serverless
# PINECONE_ENV=us-east-1

# Workspace and safety limits (optional; defaults shown)
# WORKSPACE_ROOT=./workspace
# MAX_REPO_BYTES=10485760
# MAX_FILE_BYTES=512000
# MAX_FILES_IN_PATCH=5
# MAX_PATCH_LINES=500

# Embedding model (optional)
# EMBEDDING_MODEL=text-embedding-3-small
